FROM python:3.10-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir streamlit==1.28.2 plotly==5.18.0 pandas==2.1.2 requests==2.31.0
COPY frontend ./frontend
EXPOSE 8501
ENV STYLEMI_API_URL=http://backend:8000
CMD ["streamlit", "run", "frontend/app.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
